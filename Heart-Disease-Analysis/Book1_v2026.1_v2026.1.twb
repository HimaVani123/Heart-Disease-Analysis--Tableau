      <simple-id uuid='{58BB2A58-5355-4EF3-9444-AB5A7080C30E}' />
    </dashboard>
    <dashboard name='Story 1' type='storyboard'>
      <style />
      <size maxheight='800' maxwidth='1200' minheight='800' minwidth='1200' sizing-mode='fixed' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98000' id='1' param='vert' removable='false' type-v2='layout-flow' w='98666' x='667' y='1000'>
            <zone h='5250' id='3' type-v2='title' w='98666' x='667' y='1000' />
            <zone h='12625' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='98666' x='667' y='6250' />
            <zone h='80125' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='98666' x='667' y='18875'>
              <flipboard active-id='11' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='General Health Analysis for Heart Diseases' captured-sheet='Sheet 7' id='7' />
                  <story-point caption='Gender  wise Heart Disease-Male have high count' captured-sheet='Sheet 1' id='1' />
                  <story-point caption='Race wise analysis of Heart Disease' captured-sheet='Sheet 6' id='6' />
                  <story-point caption='Impact of Smoking and Drinking ' captured-sheet='Sheet 4' id='11' />
                </story-points>
              </flipboard>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='18500' hidden='true' id='6' story-point-id='7' type-v2='text' w='45500' x='53417' y='77750'>
          <formatted-text>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Individuals reporting </run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Good</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'> and </run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Fair</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'> health contribute the largest share of heart disease cases. Very few heart disease cases are observed among people reporting </run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Excellent</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'> health. As general health declines from Excellent to Poor, the occurrence of heart disease tends to increase. General health is therefore an important indicator of cardiovascular risk</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='14375' hidden='true' id='7' story-point-id='1' type-v2='text' w='35417' x='49333' y='19750'>
          <formatted-text>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='8'>Female participants constitute a slightly larger portion of the dataset than males.The majority of individuals in both genders do </run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='8'>not</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='8'> have heart disease. Heart disease cases are present in both genders, indicating that gender alone is not the determining factor. Further analysis with age and lifestyle factors is necessary to assess overall risk</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='16500' hidden='true' id='8' story-point-id='6' type-v2='text' w='33333' x='59500' y='77125'>
          <formatted-text>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Approximately </run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>75.57%</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'> of the records belong to the White population. </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Black participants account for around </run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>17.81%</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>. </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Hispanic participants contribute approximately </run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>3.73%</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>, while other racial groups represent smaller proportions. </run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='11250' id='9' story-point-id='11' type-v2='text' w='33333' x='50000' y='41000'>
          <formatted-text>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Non-smokers represent the largest group in the dataset. </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Smokers show a comparatively higher proportion of heart disease cases. </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Alcohol consumption alone appears to have a weaker association than smoking. </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Smoking emerges as one of the important lifestyle-related risk factors for heart disease. </run>
          </formatted-text>
        </zone>
      </zones>
      <simple-id uuid='{05285FF7-3EFC-4260-9C05-1E9479796B98}' />
    </dashboard>
    <dashboard name='Story 2' type='storyboard'>
      <style />
      <size maxheight='800' maxwidth='1200' minheight='800' minwidth='1200' sizing-mode='fixed' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98000' id='1' param='vert' removable='false' type-v2='layout-flow' w='98666' x='667' y='1000'>
            <zone h='5250' id='3' type-v2='title' w='98666' x='667' y='1000' />
            <zone h='12625' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='98666' x='667' y='6250' />
            <zone h='80125' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='98666' x='667' y='18875'>
              <flipboard active-id='2' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='Age wise Heart Disease' captured-sheet='Sheet 2' id='1' />
                  <story-point caption='Age and BMI vs Diabetic' captured-sheet='Sheet 9' id='2' />
                </story-points>
              </flipboard>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
        <zone flipboard-zone-id='5' h='13750' hidden='true' id='6' story-point-id='1' type-v2='text' w='33333' x='57083' y='54750'>
          <formatted-text>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Heart disease cases gradually increase with age. </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Individuals aged </run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>60 years and above</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'> show the highest number of heart disease cases. </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Younger age groups (18–34 years) have relatively few heart disease cases.</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='13750' id='7' story-point-id='2' type-v2='text' w='33333' x='65667' y='4625'>
          <formatted-text>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Middle-aged and older adults contribute the largest diabetic population. Individuals with diabetes generally have higher BMI values. BMI and diabetes together increase the likelihood of cardiovascular complications.</run>
          </formatted-text>
        </zone>
      </zones>
      <simple-id uuid='{297338EB-CF1E-4390-851F-89CE0649FF87}' />
    </dashboard>
    <dashboard name='Story 3' type='storyboard'>
      <style />
      <size maxheight='800' maxwidth='1200' minheight='800' minwidth='1200' sizing-mode='fixed' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98000' id='1' param='vert' removable='false' type-v2='layout-flow' w='98666' x='667' y='1000'>
            <zone h='5250' id='3' type-v2='title' w='98666' x='667' y='1000' />
            <zone h='12625' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='98666' x='667' y='6250' />
            <zone h='80125' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='98666' x='667' y='18875'>
              <flipboard active-id='3' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='Stroke Count for Diabetics' captured-sheet='Sheet 3' id='1' />
                  <story-point caption='Stroke Count for Other disease' captured-sheet='Sheet 5' id='2' />
                  <story-point caption='Overall Analysis Based on Age Category' captured-sheet='Sheet 10' id='3' />
                  <story-point caption='Conclusion' captured-sheet='' id='4' />
                </story-points>
              </flipboard>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='11625' id='6' story-point-id='3' type-v2='text' w='20917' x='78250' y='6875'>
          <formatted-text>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='9'>Higher BMI values are commonly observed among diabetic stroke patients. Older age groups generally exhibit higher BMI</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='19250' hidden='true' id='7' story-point-id='2' type-v2='text' w='33333' x='60500' y='29625'>
          <formatted-text>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Most individuals have no history of stroke. </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Stroke cases are relatively higher among patients with kidney disease and other chronic illnesses. </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Multiple chronic conditions increase the overall health burden and cardiovascular risk. </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Comorbid diseases should be considered during heart disease assessment</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='13750' hidden='true' id='8' story-point-id='1' type-v2='text' w='33333' x='49333' y='27625'>
          <formatted-text>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Stroke occurrence is comparatively higher among diabetic individuals. </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Patients with both diabetes and heart disease demonstrate a greater likelihood of stroke. </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Diabetes significantly contributes to stroke risk.</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='32750' hidden='true' id='9' story-point-id='4' type-v2='text' w='78083' x='8250' y='30375'>
          <formatted-text>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book'>The dashboard analysis reveals that heart disease is influenced by several interconnected factors rather than a single cause. Age is the strongest predictor, with cases increasing significantly after 60 years. Individuals reporting poor general health, smokers, diabetic patients, and those with higher BMI show a greater likelihood of heart disease and stroke. The findings emphasize the importance of maintaining a healthy lifestyle, monitoring chronic conditions, and promoting early diagnosis to reduce cardiovascular risk.</run>
          </formatted-text>
        </zone>
      </zones>
      <simple-id uuid='{0C2122D4-724D-45FE-9BED-6018CC457360}' />
    </dashboard>
  </dashboards>
